// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                   String           @id @default(uuid())
  name                 String
  wahaSession          String?          @unique
  contacts             Contact[]
  knowledgeBundle      KnowledgeBundle?
  currentBundleVersion String?
  funnels              Funnel[]
  createdAt            DateTime         @default(now())
}

model Contact {
  id            String         @id @default(uuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  phone         String?
  name          String
  conversations Conversation[]
  memory        BusinessMemory?
  tasks         Task[]
}

model Conversation {
  id           String        @id @default(uuid())
  contactId    String
  contact      Contact       @relation(fields: [contactId], references: [id])
  status       String        // NEW, ACTIVE, RESOLVED
  interactions Interaction[]
  activeFunnel ActiveFunnel?
}

model Interaction {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  direction      String       // INBOUND, OUTBOUND
  type           String       // TEXT, AUDIO, IMAGE
  content        String
  role           String?      // user, assistant, tool
  toolCalls      Json?
  toolCallId     String?
  timestamp      DateTime     @default(now())
}

model BusinessMemory {
  id              String           @id @default(uuid())
  contactId       String           @unique
  contact         Contact          @relation(fields: [contactId], references: [id])
  name            String?
  company         String?
  interests       String[]
  lastInteraction DateTime?
  objections      String[]
  leadStatus      String?
  tags            String[]
  updatedAt       DateTime         @updatedAt
  auditLogs       MemoryAuditLog[]
}

model MemoryAuditLog {
  id             String   @id @default(uuid())
  contactId      String
  tenantId       String?
  field          String   // which field changed: name, company, interests, etc.
  previousValue  String?  // JSON-serialized previous value
  newValue       String?  // JSON-serialized new value
  source         String   @default("hermes") // hermes | human | import | webhook
  skill          String?  // e.g. update_business_memory
  confidence     Float    @default(0.85)
  conversationId String?
  createdAt      DateTime @default(now())
  memory         BusinessMemory @relation(fields: [contactId], references: [contactId])
}

model Task {
  id        String   @id @default(uuid())
  contactId String
  contact   Contact  @relation(fields: [contactId], references: [id])
  title     String
  status    String   @default("PENDING")
  dueDate   DateTime?
  createdAt DateTime @default(now())
}

model KnowledgeBundle {
  id           String   @id @default(uuid())
  tenantId     String   @unique
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  systemPrompt Json
  version      Int      @default(1)
  checksum     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Funnel {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String
  trigger   String   // Evento o keyword que lo inicia
  steps     Json     // Estructura visual/lógica de los pasos
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActiveFunnel {
  id             String       @id @default(uuid())
  conversationId String       @unique
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  funnelId       String
  currentStepId  String
  state          Json?
  updatedAt      DateTime     @updatedAt
}
